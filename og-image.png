<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8"/>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;700;800&family=DM+Sans:wght@300;400&display=swap" rel="stylesheet"/>
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body {
    width: 1200px;
    height: 630px;
    overflow: hidden;
    background: #0a0b0d;
    font-family: 'Syne', sans-serif;
  }
</style>
</head>
<body>
<svg width="1200" height="630" viewBox="0 0 1200 630" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <radialGradient id="g1" cx="25%" cy="45%" r="60%">
      <stop offset="0%" stop-color="#e8ff47" stop-opacity="0.1"/>
      <stop offset="100%" stop-color="#0a0b0d" stop-opacity="0"/>
    </radialGradient>
    <radialGradient id="g2" cx="85%" cy="70%" r="50%">
      <stop offset="0%" stop-color="#47ffb8" stop-opacity="0.06"/>
      <stop offset="100%" stop-color="#0a0b0d" stop-opacity="0"/>
    </radialGradient>
    <pattern id="dots" width="40" height="40" patternUnits="userSpaceOnUse">
      <circle cx="20" cy="20" r="0.8" fill="rgba(255,255,255,0.06)"/>
    </pattern>
  </defs>

  <!-- Base -->
  <rect width="1200" height="630" fill="#0a0b0d"/>
  <rect width="1200" height="630" fill="url(#dots)"/>
  <rect width="1200" height="630" fill="url(#g1)"/>
  <rect width="1200" height="630" fill="url(#g2)"/>

  <!-- Left accent -->
  <rect x="0" y="0" width="5" height="630" fill="#e8ff47"/>

  <!-- Top + bottom edge lines -->
  <rect x="0" y="0" width="1200" height="1" fill="rgba(255,255,255,0.07)"/>
  <rect x="0" y="629" width="1200" height="1" fill="rgba(255,255,255,0.07)"/>

  <!-- VERIFIED badge -->
  <rect x="60" y="55" width="138" height="30" rx="15" fill="rgba(232,255,71,0.1)" stroke="rgba(232,255,71,0.28)" stroke-width="1"/>
  <circle cx="82" cy="70" r="4" fill="#47ffb8"/>
  <text x="95" y="75" font-family="Syne,sans-serif" font-size="11" font-weight="700" fill="#e8ff47" letter-spacing="1.8">✓ VERIFIED</text>

  <!-- Main headline -->
  <text x="60" y="195" font-family="Syne,sans-serif" font-size="78" font-weight="800" fill="#e8e9ed" letter-spacing="-2.5">Verified Merchant</text>
  <text x="60" y="285" font-family="Syne,sans-serif" font-size="78" font-weight="800" fill="#e8ff47" letter-spacing="-2.5">Directory</text>

  <!-- Subline -->
  <text x="62" y="348" font-family="DM Sans,sans-serif" font-size="21" font-weight="300" fill="#8a8d99">24 vetted affiliate partners · 7 categories · LinkConnector verified</text>

  <!-- Divider -->
  <rect x="60" y="388" width="520" height="1" fill="rgba(255,255,255,0.09)"/>

  <!-- Stats -->
  <text x="60"  y="436" font-family="Syne,sans-serif" font-size="38" font-weight="800" fill="#e8ff47">24</text>
  <text x="60"  y="460" font-family="DM Sans,sans-serif" font-size="12" font-weight="300" fill="#8a8d99" letter-spacing="1.5">MERCHANTS</text>

  <text x="210" y="436" font-family="Syne,sans-serif" font-size="38" font-weight="800" fill="#47ffb8">7</text>
  <text x="210" y="460" font-family="DM Sans,sans-serif" font-size="12" font-weight="300" fill="#8a8d99" letter-spacing="1.5">CATEGORIES</text>

  <text x="360" y="436" font-family="Syne,sans-serif" font-size="38" font-weight="800" fill="#ff6b35">$0</text>
  <text x="360" y="460" font-family="DM Sans,sans-serif" font-size="12" font-weight="300" fill="#8a8d99" letter-spacing="1.5">EXTRA COST</text>

  <text x="510" y="436" font-family="Syne,sans-serif" font-size="38" font-weight="800" fill="#f5c842">100%</text>
  <text x="510" y="460" font-family="DM Sans,sans-serif" font-size="12" font-weight="300" fill="#8a8d99" letter-spacing="1.5">VERIFIED</text>

  <!-- URL -->
  <text x="62" y="592" font-family="DM Sans,sans-serif" font-size="15" font-weight="300" fill="rgba(138,141,153,0.5)">brightlane.github.io/verified-merchant-directory</text>

  <!-- RIGHT SIDE — category pills -->
  <rect x="740" y="75"  width="145" height="36" rx="18" fill="rgba(255,107,53,0.09)"  stroke="rgba(255,107,53,0.22)"  stroke-width="1"/>
  <text x="812" y="98"  font-family="Syne,sans-serif" font-size="13" font-weight="700" fill="#ff9a7a"  text-anchor="middle">🎬 Software</text>

  <rect x="900" y="75"  width="160" height="36" rx="18" fill="rgba(71,255,184,0.07)"  stroke="rgba(71,255,184,0.2)"   stroke-width="1"/>
  <text x="980" y="98"  font-family="Syne,sans-serif" font-size="13" font-weight="700" fill="#47ffb8"  text-anchor="middle">🎓 Education</text>

  <rect x="755" y="130" width="135" height="36" rx="18" fill="rgba(245,200,66,0.07)"  stroke="rgba(245,200,66,0.2)"   stroke-width="1"/>
  <text x="822" y="153" font-family="Syne,sans-serif" font-size="13" font-weight="700" fill="#f5c842"  text-anchor="middle">🐾 Pet Care</text>

  <rect x="908" y="130" width="145" height="36" rx="18" fill="rgba(79,172,254,0.07)"  stroke="rgba(79,172,254,0.2)"   stroke-width="1"/>
  <text x="980" y="153" font-family="Syne,sans-serif" font-size="13" font-weight="700" fill="#4facfe"  text-anchor="middle">🖼️ Print</text>

  <rect x="748" y="185" width="125" height="36" rx="18" fill="rgba(255,71,87,0.07)"   stroke="rgba(255,71,87,0.2)"    stroke-width="1"/>
  <text x="810" y="208" font-family="Syne,sans-serif" font-size="13" font-weight="700" fill="#ff6b78"  text-anchor="middle">🌿 Health</text>

  <rect x="893" y="185" width="145" height="36" rx="18" fill="rgba(175,82,222,0.07)"  stroke="rgba(175,82,222,0.2)"   stroke-width="1"/>
  <text x="965" y="208" font-family="Syne,sans-serif" font-size="13" font-weight="700" fill="#bf7fff"  text-anchor="middle">🩴 Lifestyle</text>

  <rect x="755" y="240" width="135" height="36" rx="18" fill="rgba(232,255,71,0.07)"  stroke="rgba(232,255,71,0.18)"  stroke-width="1"/>
  <text x="822" y="263" font-family="Syne,sans-serif" font-size="13" font-weight="700" fill="#e8ff47"  text-anchor="middle">⚙️ Services</text>

  <!-- Decorative watermark check -->
  <text x="1080" y="540" font-family="Syne,sans-serif" font-size="280" font-weight="800" fill="rgba(232,255,71,0.025)" text-anchor="middle">✓</text>

  <!-- Emoji cloud bottom right -->
  <text x="755"  y="370" font-size="26" fill="rgba(255,255,255,0.13)">🎬</text>
  <text x="800"  y="348" font-size="20" fill="rgba(255,255,255,0.10)">📱</text>
  <text x="840"  y="372" font-size="24" fill="rgba(255,255,255,0.09)">🐾</text>
  <text x="882"  y="352" font-size="20" fill="rgba(255,255,255,0.11)">🖼️</text>
  <text x="920"  y="374" font-size="22" fill="rgba(255,255,255,0.09)">🎓</text>
  <text x="960"  y="350" font-size="20" fill="rgba(255,255,255,0.10)">🌿</text>
  <text x="998"  y="372" font-size="24" fill="rgba(255,255,255,0.09)">🔧</text>
  <text x="1040" y="352" font-size="20" fill="rgba(255,255,255,0.10)">📄</text>
  <text x="770"  y="432" font-size="20" fill="rgba(255,255,255,0.07)">✨</text>
  <text x="815"  y="450" font-size="22" fill="rgba(255,255,255,0.08)">🎵</text>
  <text x="858"  y="430" font-size="20" fill="rgba(255,255,255,0.07)">🩴</text>
  <text x="900"  y="448" font-size="22" fill="rgba(255,255,255,0.08)">📚</text>
  <text x="945"  y="428" font-size="24" fill="rgba(255,255,255,0.07)">🐕</text>
  <text x="990"  y="446" font-size="20" fill="rgba(255,255,255,0.08)">🎃</text>
  <text x="1032" y="430" font-size="22" fill="rgba(255,255,255,0.07)">💲</text>

  <!-- Brightlane wordmark bottom right -->
  <text x="1140" y="592" font-family="Syne,sans-serif" font-size="17" font-weight="800" fill="rgba(232,255,71,0.35)" text-anchor="end" letter-spacing="-0.5">Brightlane</text>
</svg>
</body>
</html>
